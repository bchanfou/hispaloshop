# =============================================================================
# HISPALOSHOP - ARCHIVO DE CONFIGURACIÓN DE ENTORNO (.env)
# =============================================================================
# 
# INSTRUCCIONES:
# 1. Copia este archivo a .env:  cp .env.example .env
# 2. Completa los valores marcados como "REQUERIDO" (no tienen valores por defecto)
# 3. Los valores marcados como "OPCIONAL" tienen defaults seguros y puedes omitirlos
# 4. NUNCA subas tu archivo .env real a git (ya está en .gitignore)
#
# GENERACIÓN DE SECRETS:
# - JWT_SECRET: openssl rand -base64 32
# - CHAT_ENCRYPTION_KEY: openssl rand -hex 32
# - VAPID keys: npx web-push generate-vapid-keys
#
# =============================================================================


# =============================================================================
# SEGURIDAD - REQUERIDAS PARA PRODUCCIÓN
# =============================================================================

# JWT_SECRET: Clave secreta para firmar tokens JWT (mínimo 32 caracteres)
# CRÍTICA: Genera una clave segura con: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-here-change-this-to-a-secure-random-string-min-32-chars

# JWT_ALGORITHM: Algoritmo de firma JWT (default: HS256)
# OPCIONAL: No cambiar salvo que sepas lo que haces
# JWT_ALGORITHM=HS256

# ACCESS_TOKEN_EXPIRE_MINUTES: Tiempo de expiración del access token en minutos
# OPCIONAL: Default 30 minutos
# ACCESS_TOKEN_EXPIRE_MINUTES=30

# REFRESH_TOKEN_EXPIRE_DAYS: Tiempo de expiración del refresh token en días
# OPCIONAL: Default 7 días
# REFRESH_TOKEN_EXPIRE_DAYS=7


# =============================================================================
# BASE DE DATOS - MongoDB (REQUERIDA)
# =============================================================================

# MONGO_URL: URL de conexión a MongoDB
# CRÍTICA: Formato mongodb://user:pass@host:port/db o mongodb+srv:// para Atlas
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/hispaloshop

# DB_NAME: Nombre de la base de datos
# OPCIONAL: Default "hispaloshop"
# DB_NAME=hispaloshop


# =============================================================================
# PAGOS - Stripe (OPCIONAL para arrancar, REQUERIDO para checkout)
# =============================================================================

# STRIPE_SECRET_KEY: Clave secreta de Stripe
# OPCIONAL para desarrollo, REQUERIDA para producción
# Formato: sk_test_... (test) o sk_live_... (producción)
# STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# STRIPE_WEBHOOK_SECRET: Secreto para validar webhooks de Stripe
# OPCIONAL: Necesario para recibir eventos de Stripe
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# STRIPE_PUBLISHABLE_KEY: Clave pública de Stripe (pk_test_... o pk_live_...)
# OPCIONAL: Para el frontend de pagos
# STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here


# =============================================================================
# CONFIGURACIÓN GENERAL
# =============================================================================

# ENV: Entorno de ejecución (development, staging, production)
# OPCIONAL: Default "development"
# ENV=development

# DEBUG: Modo debug (true/false)
# OPCIONAL: Default false. NO activar en producción
# DEBUG=false

# PORT: Puerto del servidor backend
# OPCIONAL: Default 8000
# PORT=8000


# =============================================================================
# CORS - Orígenes permitidos
# =============================================================================

# ALLOWED_ORIGINS: Lista separada por comas de orígenes permitidos
# OPCIONAL: Default localhost para desarrollo
# En producción, usa dominios específicos (NO wildcard * con credenciales)
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173


# =============================================================================
# REDIS - Caché y sesiones (OPCIONAL)
# =============================================================================

# REDIS_URL: URL de conexión a Redis
# OPCIONAL: Para caché, rate limiting y sesiones
# REDIS_URL=redis://localhost:6379/0


# =============================================================================
# CLOUDINARY - Almacenamiento de imágenes (OPCIONAL)
# =============================================================================

# CLOUDINARY_CLOUD_NAME: Nombre del cloud en Cloudinary
# OPCIONAL: Requerido si usas Cloudinary para imágenes
# CLOUDINARY_CLOUD_NAME=your-cloud-name

# CLOUDINARY_API_KEY: API Key de Cloudinary
# OPCIONAL: Requerido si usas Cloudinary
# CLOUDINARY_API_KEY=your_api_key_here

# CLOUDINARY_API_SECRET: API Secret de Cloudinary
# OPCIONAL: Requerido si usas Cloudinary
# CLOUDINARY_API_SECRET=your_api_secret_here


# =============================================================================
# EMAIL - Notificaciones y comunicaciones
# =============================================================================

# RESEND_API_KEY: API Key de Resend para envío de emails
# OPCIONAL: Requerido para enviar emails transaccionales
# RESEND_API_KEY=re_your_resend_api_key_here

# EMAIL_FROM: Remitente por defecto de los emails
# OPCIONAL: Default "Hispaloshop <noreply@hispaloshop.com>"
# EMAIL_FROM=Hispaloshop <noreply@hispaloshop.com>

# FRONTEND_URL: URL pública del frontend
# OPCIONAL: Default https://www.hispaloshop.com (producción)
# FRONTEND_URL=http://localhost:3000

# AUTH_BACKEND_URL: URL del backend para autenticación
# OPCIONAL: Default http://localhost:8000
# AUTH_BACKEND_URL=http://localhost:8000

# GOOGLE_CLIENT_ID: Client ID de OAuth de Google
# OPCIONAL: Para login con Google
# GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# GOOGLE_CLIENT_SECRET: Client Secret de OAuth de Google
# OPCIONAL: Para login con Google
# GOOGLE_CLIENT_SECRET=your_google_client_secret_here


# =============================================================================
# PLATAFORMA - Configuración de comisiones
# =============================================================================

# PLATFORM_COMMISSION: Comisión de la plataforma (0.20 = 20%)
# OPCIONAL: Default 0.20 (20%)
# PLATFORM_COMMISSION=0.20


# =============================================================================
# OPENAI - Embeddings y recomendaciones (OPCIONAL)
# =============================================================================

# OPENAI_API_KEY: API Key de OpenAI
# OPCIONAL: Para embeddings de productos y recomendaciones AI
# OPENAI_API_KEY=sk-your_openai_api_key_here

# OPENAI_ORG_ID: ID de organización de OpenAI (opcional)
# OPCIONAL: Solo si usas organización específica
# OPENAI_ORG_ID=org-your_org_id


# =============================================================================
# GOOGLE CLOUD TRANSLATION (OPCIONAL)
# =============================================================================

# GOOGLE_TRANSLATE_API_KEY: API Key de Google Cloud Translation
# OPCIONAL: Para traducción automática de contenidos
# GOOGLE_TRANSLATE_API_KEY=your_google_translate_api_key_here


# =============================================================================
# ANTHROPIC - AI Assistants (David/Rebeca/Pedro/Commercial) (OPCIONAL)
# =============================================================================

# ANTHROPIC_API_KEY: API Key de Anthropic (Claude)
# OPCIONAL: Para asistentes AI de la plataforma
# ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here

# HISPAL_AI_MODEL: Modelo Claude para el asistente general
# OPCIONAL: Default "claude-haiku-4-5-20251001"
# HISPAL_AI_MODEL=claude-haiku-4-5-20251001

# HISPAL_AI_RATE_LIMIT_RPM: Rate limit en requests por minuto
# OPCIONAL: Default 20
# HISPAL_AI_RATE_LIMIT_RPM=20

# COMMERCIAL_AI_MODEL: Modelo Claude para el asistente comercial
# OPCIONAL: Default "claude-sonnet-4-6"
# COMMERCIAL_AI_MODEL=claude-sonnet-4-6

# REBECA_AI_MODEL: Modelo Claude para el asistente Rebeca
# OPCIONAL: Default "claude-haiku-4-5-20251001"
# REBECA_AI_MODEL=claude-haiku-4-5-20251001


# =============================================================================
# FCM - Firebase Cloud Messaging (OPCIONAL)
# =============================================================================

# FCM_SERVICE_ACCOUNT_JSON: Credenciales de servicio de Firebase (JSON en una línea)
# OPCIONAL: Para notificaciones push
# FCM_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}


# =============================================================================
# WEB PUSH - Notificaciones push del navegador (OPCIONAL)
# =============================================================================

# VAPID_PUBLIC_KEY: Clave pública VAPID (compartir con frontend)
# OPCIONAL: Generar con: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=your_vapid_public_key_here

# VAPID_PRIVATE_KEY: Clave privada VAPID (solo backend)
# OPCIONAL: Generar con: npx web-push generate-vapid-keys
# VAPID_PRIVATE_KEY=your_vapid_private_key_here

# VAPID_EMAIL: Email del admin para VAPID
# OPCIONAL: Default "mailto:admin@hispaloshop.com"
# VAPID_EMAIL=mailto:admin@hispaloshop.com


# =============================================================================
# CHAT ENCRYPTION - Cifrado de mensajes (OPCIONAL)
# =============================================================================

# CHAT_ENCRYPTION_KEY: Clave AES-256-GCM en formato hex (32 bytes = 64 caracteres hex)
# OPCIONAL: Generar con: openssl rand -hex 32
# CHAT_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef


# =============================================================================
# STRIPE BILLING - Webhooks de suscripción (OPCIONAL)
# =============================================================================

# STRIPE_BILLING_WEBHOOK_SECRET: Secreto separado para webhooks de billing
# OPCIONAL: Para eventos de suscripciones
# STRIPE_BILLING_WEBHOOK_SECRET=whsec_your_billing_webhook_secret_here


# =============================================================================
# BACKEND URL - URL pública del API (OPCIONAL)
# =============================================================================

# BACKEND_URL: URL pública del backend (para emails y webhooks)
# OPCIONAL: Si no se define, usa AUTH_BACKEND_URL
# BACKEND_URL=https://api.hispaloshop.com


# =============================================================================
# MONITORING - Sentry error tracking (OPCIONAL)
# =============================================================================

# SENTRY_DSN: DSN de Sentry para tracking de errores
# OPCIONAL: Para monitoreo de errores en producción
# SENTRY_DSN=https://your_sentry_dsn_here@o000000.ingest.sentry.io/0000000

# SENTRY_RELEASE: Identificador de release (git SHA recomendado)
# OPCIONAL: Para trackear errores por versión
# SENTRY_RELEASE=1.0.0

# SENTRY_TRACES_RATE: Porcentaje de requests a muestrear (0.0 - 1.0)
# OPCIONAL: Default 0.1 (10%)
# SENTRY_TRACES_RATE=0.1


# =============================================================================
# OBSERVABILITY - Logging estructurado
# =============================================================================

# LOG_LEVEL: Nivel de logging (DEBUG | INFO | WARNING | ERROR | CRITICAL)
# OPCIONAL: Default "INFO"
# LOG_LEVEL=INFO


# =============================================================================
# CRON ADMIN - Token para tareas programadas (OPCIONAL)
# =============================================================================

# CRON_ADMIN_TOKEN: JWT de admin de larga duración para GitHub Actions
# OPCIONAL: Para ejecutar tareas cron desde CI/CD
# CRON_ADMIN_TOKEN=your_long_lived_jwt_token_here


# =============================================================================
# CSRF - Protección contra ataques CSRF
# =============================================================================

# CSRF_ENABLED: Activar protección CSRF (true/false)
# OPCIONAL: Default true (NO desactivar en producción)
# CSRF_ENABLED=true


# =============================================================================
# FRONTEND SENTRY (REACT) - Variables para el frontend
# Estas variables deben ir en frontend/.env para producción
# =============================================================================

# REACT_APP_SENTRY_DSN: DSN para el frontend React
# OPCIONAL: Altamente recomendado para producción
# REACT_APP_SENTRY_DSN=https://your_sentry_dsn_here@o000000.ingest.sentry.io/0000000

# REACT_APP_SENTRY_RELEASE: Debe coincidir con el backend (git SHA)
# OPCIONAL: Usar el mismo valor que SENTRY_RELEASE
# REACT_APP_SENTRY_RELEASE=1.0.0

# REACT_APP_ENVIRONMENT: Entorno del frontend
# OPCIONAL: Default "production"
# REACT_APP_ENVIRONMENT=production

# SENTRY_AUTH_TOKEN: Token para subir source maps (solo CI/CD)
# OPCIONAL: Necesario en GitHub Actions. Generar en: Sentry > Settings > Auth Tokens
# SENTRY_AUTH_TOKEN=sntrys_ey...

# SENTRY_ORG: Organización de Sentry
# OPCIONAL: Para source maps upload
# SENTRY_ORG=your-org

# SENTRY_PROJECT: Proyecto de Sentry
# OPCIONAL: Para source maps upload
# SENTRY_PROJECT=your-project
