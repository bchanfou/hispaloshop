# ============================================
# HISPALOSHOP - CONFIGURACIÓN OBLIGATORIA
# ============================================
# Copiar este archivo a .env y rellenar los valores
# NUNCA commitear el archivo .env real

# ============================================
# SEGURIDAD - OBLIGATORIO
# Generar con: openssl rand -hex 32
# Mínimo 32 caracteres. NO usar valores de ejemplo.
JWT_SECRET=

# ============================================
# BASE DE DATOS - MongoDB (única fuente de verdad MVP)
# ============================================
# URL de conexión a MongoDB Atlas o local
MONGO_URL=mongodb+srv://usuario:password@cluster.mongodb.net/hispaloshop?retryWrites=true&w=majority
# Nombre de la base de datos
DB_NAME=hispaloshop

# ============================================
# PAGOS - Stripe (obtener de dashboard.stripe.com)
# ============================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# ============================================
# CONFIGURACIÓN GENERAL
# ============================================
ENV=development
DEBUG=true

# ============================================
# CORS - Orígenes permitidos (separados por coma, sin espacios)
# En producción: lista explícita de dominios, NUNCA usar *
# ============================================
ALLOWED_ORIGINS=https://hispaloshop.com,https://www.hispaloshop.com,http://localhost:3000

# ============================================
# OPCIONALES (mejoran experiencia pero no bloquean)
# ============================================

# Redis (para rate limiting distribuido y cache)
REDIS_URL=redis://localhost:6379/0

# Cloudinary (para almacenamiento de imágenes)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=Hispaloshop <onboarding@resend.dev>
FRONTEND_URL=https://hispaloshop.com
AUTH_BACKEND_URL=https://api.hispaloshop.com

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI/LLM (Emergent)
EMERGENT_LLM_KEY=

# OPENAI (para embeddings y recomendaciones)
OPENAI_API_KEY=sk-...
OPENAI_ORG_ID=  # Opcional

# Configuración de plataforma
PLATFORM_COMMISSION=0.20

# ============================================
# VALIDACIÓN AL INICIO
# ============================================
# La aplicación fallará al iniciar si faltan:
# - JWT_SECRET (mínimo 32 caracteres, no valores de ejemplo)
# - MONGO_URL (debe empezar con mongodb:// o mongodb+srv://)
# - STRIPE_SECRET_KEY (debe empezar con sk_test_ o sk_live_)
#
# Ejecutar verificación:
#   cd backend && python scripts/verify_setup.py
# ============================================
