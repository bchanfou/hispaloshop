# HISPALOSHOP - Environment Configuration
# Copy to .env and fill with real values

# === REQUIRED ===
# Generate with: openssl rand -hex 32
JWT_SECRET=

# MongoDB connection string
MONGO_URL=mongodb+srv://user:password@cluster.mongodb.net/hispaloshop

# Stripe API keys (test mode for development)
STRIPE_SECRET_KEY=sk_test_...

# === CORS / SECURITY ===
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# === OPTIONAL ===
# Stripe webhook secret (required for webhook processing)
STRIPE_WEBHOOK_SECRET=whsec_...

# Cloudinary for image uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Redis for rate limiting and caching
REDIS_URL=redis://localhost:6379/0

# Environment (development, staging, production)
ENV=development

# Port (Railway sets this automatically)
PORT=8000
