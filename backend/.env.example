# ═══════════════════════════════════════════════════════════════════════════
# HISPALOSHOP BACKEND — Environment Variables
# ---------------------------------------------------------------------------
# Copy this file to `.env` in the backend dir (or at repo root) and fill in.
# NEVER commit the real `.env` file — it's in .gitignore.
#
# Critical vars policy (see backend/core/env_validation.py):
# - `MONGO_URL` + `JWT_SECRET` are always required (pydantic raises at import).
# - In ENV=staging or ENV=production the following ALSO block startup if
#   missing: STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET, ANTHROPIC_API_KEY,
#   FCM_SERVICE_ACCOUNT_JSON, FRONTEND_URL, BACKEND_URL.
# - In ENV=development missing vars only log a warning — the backend starts
#   with degraded capabilities (Stripe disabled, AI disabled, etc.) so new
#   devs can clone + run without every third-party account.
# ═══════════════════════════════════════════════════════════════════════════


# ─── Environment ────────────────────────────────────────────────────────────
# development | staging | production
# Controls log format (JSON in staging/prod, readable in dev) and whether
# missing critical vars raise at startup or just warn.
ENV=development
DEBUG=true
PORT=8000

# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO


# ─── Security — REQUIRED ALWAYS ─────────────────────────────────────────────
# Min 32 chars. Generate with:  openssl rand -hex 32
# In production must NOT contain example values ("change-me", "secret123"...).
JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CSRF double-submit cookie (active by default)
CSRF_ENABLED=true

# Chat message encryption (AES-256-GCM, 32-byte hex). Optional in dev,
# strongly recommended in production. Generate with: openssl rand -hex 32
CHAT_ENCRYPTION_KEY=


# ─── Database — REQUIRED ALWAYS ─────────────────────────────────────────────
# MongoDB Atlas or local MongoDB.
MONGO_URL=mongodb+srv://user:pass@cluster.mongodb.net/hispaloshop?retryWrites=true&w=majority
DB_NAME=hispaloshop


# ─── URLs — REQUIRED in staging/prod ────────────────────────────────────────
# Public URL of the frontend (used for CORS allowlist + email links).
FRONTEND_URL=http://localhost:3000

# Public URL of this API. Preferred over AUTH_BACKEND_URL (legacy alias).
# Used for email link generation and webhook callbacks.
BACKEND_URL=http://localhost:8000

# Legacy alias — still read by older services. Leave blank if BACKEND_URL set.
AUTH_BACKEND_URL=http://localhost:8000

# Comma-separated CORS allowlist. NO wildcards in production.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173


# ─── Payments — Stripe (REQUIRED in staging/prod) ───────────────────────────
# Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Separate webhook for subscription billing events (optional but recommended)
STRIPE_BILLING_WEBHOOK_SECRET=whsec_...


# ─── AI — Anthropic Claude (REQUIRED in staging/prod) ───────────────────────
# Used by David (B2C), Rebeca (PRO+), Pedro (ELITE), Commercial AI.
# Dashboard: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# AI model overrides (defaults are production-ready)
HISPAL_AI_MODEL=claude-haiku-4-5-20251001
HISPAL_AI_RATE_LIMIT_RPM=20
COMMERCIAL_AI_MODEL=claude-sonnet-4-6
REBECA_AI_MODEL=claude-haiku-4-5-20251001


# ─── Push Notifications — FCM (REQUIRED in staging/prod) ────────────────────
# JSON-encoded Firebase service account credentials (entire JSON as a single
# env var value — escape newlines in the private_key field).
# Firebase Console → Project Settings → Service Accounts → Generate new key.
# Then paste the JSON content as a single-line value here.
FCM_SERVICE_ACCOUNT_JSON=


# ─── Web Push — VAPID (optional, recommended for production push) ──────────
# Generate with:  npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY must also be exposed to frontend as REACT_APP_VAPID_PUBLIC_KEY.
# VAPID_PRIVATE_KEY must stay backend-only.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@hispaloshop.com


# ─── Email — Resend (optional, recommended) ────────────────────────────────
# Dashboard: https://resend.com/api-keys
RESEND_API_KEY=
EMAIL_FROM=Hispaloshop <noreply@hispaloshop.com>


# ─── Image Storage — Cloudinary (optional, recommended) ────────────────────
# Dashboard: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=


# ─── OAuth — Google (optional, enables Google Sign-In) ─────────────────────
# Console: https://console.cloud.google.com/apis/credentials
# NOTE: legacy code also reads GOOGLE_OAUTH_CLIENT_ID / GOOGLE_AUTH_CLIENT_ID
# as fallbacks — GOOGLE_CLIENT_ID is the canonical name.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# ─── Google Cloud Translation (optional, for auto-translate features) ──────
GOOGLE_TRANSLATE_API_KEY=


# ─── OpenAI (optional, only for embeddings) ────────────────────────────────
# Consumer AI chat uses Anthropic Claude, NOT OpenAI. This is only for
# vector embeddings in product search / recommendations.
OPENAI_API_KEY=
OPENAI_ORG_ID=


# ─── Caching — Redis (optional, in-memory fallback if absent) ──────────────
REDIS_URL=redis://localhost:6379/0


# ─── Monitoring — Sentry (optional, highly recommended in staging/prod) ────
# Create project at https://sentry.io → copy DSN here.
SENTRY_DSN=

# Release identifier for error-to-commit mapping. In CI/CD, set to git SHA:
#   Railway:        SENTRY_RELEASE=${RAILWAY_GIT_COMMIT_SHA}
#   GitHub Actions: SENTRY_RELEASE=${{ github.sha }}
# Fallbacks: RAILWAY_GIT_COMMIT_SHA → APP_VERSION → "unknown"
SENTRY_RELEASE=

# Traces sample rate (0.0–1.0). 0.1 = 10% of requests traced.
SENTRY_TRACES_RATE=0.1


# ─── GitHub Actions Cron (long-lived admin JWT) ────────────────────────────
# Used by .github/workflows/cron-daily.yml and cron-weekly.yml to call
# /api/admin/cron/* endpoints. Stored as a GH Actions secret, passed as
# "Authorization: Bearer $CRON_ADMIN_TOKEN".
CRON_ADMIN_TOKEN=


# ─── Platform economics (optional — sensible defaults) ─────────────────────
PLATFORM_COMMISSION=0.20
AFFILIATE_ATTRIBUTION_DAYS=540
AFFILIATE_COOKIE_NAME=hsp_ref
AFFILIATE_MIN_PAYOUT_CENTS=2000


# ═══════════════════════════════════════════════════════════════════════════
# Verify your setup:
#   cd backend && python scripts/verify_setup.py
#
# Test import with minimal dev config:
#   ENV=development JWT_SECRET=$(openssl rand -hex 32) \
#     MONGO_URL=mongodb://localhost:27017 python -c "import main"
# ═══════════════════════════════════════════════════════════════════════════
