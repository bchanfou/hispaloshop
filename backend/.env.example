# Core app
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# SQL database (primary app models)
DATABASE_URL=postgresql+asyncpg://user:pass@localhost/hispaloshop

# Legacy Mongo layer (still used by /routes/* endpoints)
MONGO_URL=mongodb://localhost:27017
DB_NAME=hispaloshop

# Auth / security
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ELITE=
STRIPE_PUBLISHABLE_KEY=

# OpenAI (optional in local dev; app boots without it)
OPENAI_API_KEY=
OPENAI_ORG_ID=

# Cloudinary (optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Firebase (optional)
FIREBASE_CREDENTIALS=

# Redis (optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Affiliate / tier jobs
AFFILIATE_ATTRIBUTION_DAYS=548
AFFILIATE_COOKIE_NAME=hispaloshop_ref
AFFILIATE_MIN_PAYOUT_CENTS=1000
TIER_RECALCULATION_DAY=1
