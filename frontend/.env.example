# ═══════════════════════════════════════════════════════════════════════════
# HISPALOSHOP FRONTEND — Environment Variables (Create React App / Craco)
# ---------------------------------------------------------------------------
# Copy to `.env` or `.env.local`. All client-side vars MUST start with
# `REACT_APP_` (CRA convention) to be exposed to the bundle.
# NEVER put secrets here — everything in this file ships to the browser.
# ═══════════════════════════════════════════════════════════════════════════


# ─── API Backend ────────────────────────────────────────────────────────────
# Public URL of the backend API. In dev, craco.config.js sets up a proxy to
# http://localhost:8000 automatically if REACT_APP_API_URL is not set.
REACT_APP_API_URL=https://api.hispaloshop.com
REACT_APP_API_PREFIX=/api
REACT_APP_API_FALLBACK_PREFIX=/api/v1
REACT_APP_API_TIMEOUT=30000

# Optional: backend URL for dev proxy (only read when REACT_APP_API_URL is blank)
REACT_APP_BACKEND_URL=http://localhost:8000

# WebSocket URL (auto-derived from API_URL if not specified)
REACT_APP_WS_URL=


# ─── Environment ────────────────────────────────────────────────────────────
# development | staging | production
# REACT_APP_ENVIRONMENT is the canonical name. REACT_APP_ENV is a legacy alias.
REACT_APP_ENVIRONMENT=development
REACT_APP_ENV=development


# ─── Payments — Stripe (publishable key only, never secret) ────────────────
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_test_...


# ─── Image Storage — Cloudinary (client-side direct uploads) ───────────────
REACT_APP_CLOUDINARY_CLOUD=
REACT_APP_CLOUDINARY_PRESET=hispaloshop_unsigned


# ─── Web Push — VAPID Public Key ───────────────────────────────────────────
# Must match backend VAPID_PUBLIC_KEY. The PRIVATE key must NEVER appear here.
REACT_APP_VAPID_PUBLIC_KEY=


# ─── GIPHY (sticker tool) ──────────────────────────────────────────────────
REACT_APP_GIPHY_API_KEY=


# ─── OAuth — Google Sign-In client ID ──────────────────────────────────────
REACT_APP_GOOGLE_CLIENT_ID=


# ─── Monitoring — Sentry (optional but recommended in staging/prod) ────────
# Frontend DSN is a separate DSN from the backend (one per Sentry project).
# Init is conditional: no DSN → Sentry disabled, no crash.
REACT_APP_SENTRY_DSN=

# Release identifier (git SHA). Links errors to deploys.
# In CI/CD: REACT_APP_SENTRY_RELEASE=${{ github.sha }}
# Fallback: REACT_APP_VERSION.
REACT_APP_SENTRY_RELEASE=
REACT_APP_VERSION=1.0.0


# ─── Build options ─────────────────────────────────────────────────────────
# Disable source map generation in the production bundle — smaller build +
# no source exposure. Upload source maps to Sentry separately via CLI
# (see DEPLOYMENT.md → "Upload source maps to Sentry").
GENERATE_SOURCEMAP=false


# ─── Dev / demo flags ──────────────────────────────────────────────────────
REACT_APP_USE_MOCK=false
REACT_APP_DEMO_MODE=false
