REACT_APP_API_URL=https://api.hispaloshop.com
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_live_...
REACT_APP_CLOUDINARY_CLOUD=...
REACT_APP_CLOUDINARY_PRESET=hispaloshop_unsigned
REACT_APP_GIPHY_API_KEY=<tu key de produccion>

# Observabilidad (opcional, recomendado en producción)
REACT_APP_SENTRY_DSN=
REACT_APP_ENV=development
REACT_APP_VERSION=1.0.0

# API config (opcionales, tienen defaults)
REACT_APP_API_PREFIX=/api
REACT_APP_API_FALLBACK_PREFIX=/api/v1
REACT_APP_API_TIMEOUT=30000

# Web Push (opcional)
REACT_APP_VAPID_PUBLIC_KEY=

# Backend alternativo (si diferente de REACT_APP_API_URL)
REACT_APP_BACKEND_URL=

# WebSocket URL (auto-derivado de API_URL si no se especifica)
REACT_APP_WS_URL=

# Modo demo/mock (solo desarrollo)
REACT_APP_USE_MOCK=false
REACT_APP_DEMO_MODE=false
