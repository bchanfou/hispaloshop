{
  "project_name": "Hispaloshop",
  "design_philosophy": {
    "identity": "E1 - The Anti-AI Designer",
    "core_principles": [
      "Fusion over Imitation: Mix Instagram's fluidity with Amazon's utility.",
      "Emotion First: Every pixel must convey 'Local Quality' and 'Trust'.",
      "Content is King: Data is the story. Charts and metrics are the heroes.",
      "Zoom In: Use bold focus on essential metrics (Store Health).",
      "Negative Space: Pinterest-style breathing room for data density."
    ],
    "anti_patterns": [
      "No generic 'Bootstrap' grids.",
      "No 'Inter everywhere' without weight/tracking variation.",
      "No gradient overload - use texture instead.",
      "No center-everything layouts - use asymmetry for tension."
    ]
  },
  "typography": {
    "font_family": {
      "primary": "Inter, sans-serif",
      "display": "Cinzel, serif"
    },
    "usage_rules": {
      "headings": {
        "font": "Inter",
        "weight": "700",
        "tracking": "-0.02em",
        "notes": "Use 'Cinzel' ONLY for Storefront/Public Brand moments. Dashboards must use 'Inter' for legibility."
      },
      "body": {
        "font": "Inter",
        "weight": "400",
        "tracking": "normal"
      },
      "labels": {
        "font": "Inter",
        "weight": "500",
        "transform": "uppercase",
        "tracking": "0.05em",
        "size": "0.75rem"
      }
    },
    "scale": {
      "mobile": {
        "h1": "32px",
        "h2": "24px",
        "body": "16px"
      },
      "desktop": {
        "h1": "48px",
        "h2": "32px",
        "body": "16px"
      }
    }
  },
  "colors": {
    "palette": {
      "primary": "#1A1A1A",
      "secondary": "#F5F5F0",
      "accent_success": "#2D5A27",
      "accent_alert": "#C41E3A",
      "neutral_100": "#FFFFFF",
      "neutral_200": "#E5E5E5",
      "neutral_900": "#1A1A1A"
    },
    "usage": {
      "background": "#F5F5F0",
      "cards": "#FFFFFF",
      "text_main": "#1A1A1A",
      "text_muted": "#666666",
      "cta_primary": "#2D5A27",
      "cta_critical": "#C41E3A"
    },
    "gradients": {
      "hero_fade": "linear-gradient(180deg, rgba(245,245,240,0) 0%, #F5F5F0 100%)",
      "glass_surface": "rgba(255, 255, 255, 0.7)"
    }
  },
  "layout_system": {
    "breakpoints": {
      "mobile": "320px - 767px",
      "tablet": "768px - 1023px",
      "desktop": "1024px - 1439px",
      "wide": "1440px+"
    },
    "grid_system": {
      "mobile": "grid-cols-1 gap-4 p-4",
      "tablet": "grid-cols-2 gap-6 p-6",
      "desktop": "grid-cols-12 gap-8 p-8"
    },
    "dashboard_layouts": {
      "mobile_seller": {
        "structure": "Vertical Stack",
        "elements": [
          "Header (Store Health Score)",
          "Grid 2-col (Sales, Orders)",
          "Horizontal Scroll (Quick Actions)",
          "Chart Widget",
          "Floating Action Button (AI)"
        ]
      },
      "desktop_admin": {
        "structure": "Sidebar + Masonry Grid",
        "sidebar": "Fixed Left (240px)",
        "main_content": "Fluid Grid (minmax(300px, 1fr))"
      }
    }
  },
  "components": {
    "buttons": {
      "mobile": "h-12 rounded-xl text-base font-medium w-full",
      "desktop": "h-10 rounded-lg text-sm font-medium px-6",
      "styles": {
        "primary": "bg-[#2D5A27] text-white hover:bg-[#23461F] shadow-lg hover:shadow-xl transition-all",
        "secondary": "bg-white border border-[#E5E5E5] text-[#1A1A1A] hover:bg-[#F5F5F0]",
        "ghost": "text-[#666666] hover:text-[#1A1A1A] hover:bg-black/5"
      }
    },
    "cards": {
      "base": "bg-white rounded-xl border border-black/5 shadow-[0_2px_8px_rgba(0,0,0,0.04)]",
      "interactive": "hover:-translate-y-1 hover:shadow-[0_8px_24px_rgba(0,0,0,0.08)] transition-all duration-300",
      "glass": "backdrop-blur-xl bg-white/80 border border-white/20"
    },
    "inputs": {
      "base": "h-12 (mobile) / h-10 (desktop) bg-white border border-[#E5E5E5] rounded-lg px-4 focus:ring-2 focus:ring-[#2D5A27]/20 focus:border-[#2D5A27] transition-all"
    },
    "navigation": {
      "mobile_bottom": "fixed bottom-0 left-0 right-0 h-16 bg-white/90 backdrop-blur-lg border-t border-black/5 flex justify-around items-center z-50",
      "desktop_sidebar": "fixed left-0 top-0 h-full w-64 bg-white border-r border-black/5 p-6 flex flex-col gap-2"
    }
  },
  "visual_enhancers": {
    "shadows": {
      "soft": "0 2px 8px rgba(0,0,0,0.04)",
      "medium": "0 8px 24px rgba(0,0,0,0.08)",
      "floating": "0 16px 48px rgba(0,0,0,0.12)"
    },
    "radius": {
      "sm": "4px",
      "md": "8px",
      "lg": "12px",
      "xl": "16px",
      "full": "9999px"
    },
    "animations": {
      "hover": "transition-all duration-200 ease-out",
      "enter": "animate-in fade-in slide-in-from-bottom-4 duration-500",
      "exit": "animate-out fade-out slide-out-to-bottom-4 duration-300"
    }
  },
  "assets": {
    "images": {
      "artisan_potter": "https://images.unsplash.com/photo-1589051079002-b140a970f568?crop=entropy&cs=srgb&fm=jpg&q=85",
      "artisan_workshop": "https://images.unsplash.com/photo-1716876995651-1ff85b65a6d9?crop=entropy&cs=srgb&fm=jpg&q=85",
      "product_oil_1": "https://images.unsplash.com/photo-1766984702326-1340e8dd38f0?crop=entropy&cs=srgb&fm=jpg&q=85",
      "product_oil_2": "https://images.unsplash.com/photo-1611930021592-a8cfd5319ceb?crop=entropy&cs=srgb&fm=jpg&q=85"
    },
    "icons": "Use Lucide-React for all UI icons. Use Phosphor Icons for 'Brand' moments if needed."
  },
  "universal_guidelines_for_main_agent": [
    "DO NOT use generic 'Bootstrap' layouts. Use CSS Grid with asymmetry.",
    "DO NOT use gradients for backgrounds. Use solid colors or subtle noise textures.",
    "ALWAYS use 'Inter' for UI text, but use 'Cinzel' for Storefront Headings.",
    "ALWAYS add 'data-testid' to interactive elements.",
    "Use 'sonner' for toasts.",
    "Use 'recharts' for data visualization with minimal styling (hide axes, use curves).",
    "Mobile First: Design for 320px width first, then scale up.",
    "Accessibility: Ensure 4.5:1 contrast ratio for text. Use 'aria-label' for icon buttons."
  ]
}